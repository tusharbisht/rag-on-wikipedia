{
  "branch": "exercise/07-vector-scale",
  "endpoint": "GET /health",
  "tests": [
    {
      "id": "health-declares-real-index",
      "endpoint_override": "GET /health",
      "weight": 1.0,
      "type": "contract",
      "expected": {
        "status": 200
      }
    },
    {
      "id": "latency-slo-p95-under-load",
      "endpoint_override": "POST /search",
      "weight": 1.0,
      "type": "regression",
      "input": {
        "question": "Who founded Microsoft?",
        "user_id": "judge_42"
      },
      "expected": {
        "status": 200,
        "body_contains": [
          "Gates"
        ]
      }
    },
    {
      "id": "cold-restart-index-persists",
      "endpoint_override": "GET /health",
      "weight": 1.0,
      "type": "contract",
      "expected": {
        "status": 200
      }
    },
    {
      "id": "under-load-no-regression",
      "endpoint_override": "POST /search",
      "weight": 1.0,
      "type": "regression",
      "input": {
        "question": "What is the boiling point of water?",
        "user_id": "judge_42"
      },
      "expected": {
        "status": 200,
        "body_contains": [
          "100"
        ],
        "citation_verbatim": true
      }
    },
    {
      "id": "prose-no-regression",
      "endpoint_override": "POST /search",
      "weight": 1.0,
      "type": "regression",
      "input": {
        "question": "Who wrote Hamlet?",
        "user_id": "judge_42"
      },
      "expected": {
        "status": 200,
        "body_contains": [
          "Shakespeare"
        ]
      }
    }
  ]
